# Example configuration for wowrag. Copy to .env and adjust.
# .env is gitignored and MUST NOT contain real secrets.

# PostgreSQL DSN for the pgvector store (use a real password in .env, not here).
POSTGRES_DSN=postgresql://wowrag:CHANGE_ME@localhost:5432/wowrag

# Local Ollama endpoint.
OLLAMA_URL=http://localhost:11434

# Local LLM model served by Ollama.
LLM_MODEL=qwen2.5:7b-instruct

# Multilingual embedding model and its vector dimension.
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Retrieval settings: number of chunks and abstention score threshold.
TOP_K=5
SCORE_THRESHOLD=0.30

# Default persona name (resolves to src/wowrag/personas/<name>.yaml).
DEFAULT_PERSONA=simple

# CORS for the future in-game frontend (f9). Lists are expressed as JSON.
# "*" is the explicit default; close it to a list of allowed origins, e.g.
# CORS_ALLOW_ORIGINS=["https://game.example"]
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
